{
  "name": "Babymart",
  "displayName": "Babymart",
  "expo": {
    "name": "Babymart",
    "slug": "babymart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#29beb3"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.babymart.app",
      "infoPlist": {
        "CFBundleDisplayName": "Babymart"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#29beb3"
      },
      "package": "com.babymart.app"
    }
  }
}

# Babymart Mobile App - Environment Configuration
# Copy this file to .env and update with your actual values

# API URLs
# For local development
API_ENDPOINT=http://localhost:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# For production, update these values
# API_ENDPOINT=https://api.babymart.com/api
# NEXT_PUBLIC_API_URL=https://api.babymart.com/api

# Stripe Payment Keys
# Development keys
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# Production keys (uncomment for production)
# STRIPE_PUBLISHABLE_KEY=pk_live_your_live_key_here

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Pricing Configuration
TAX_AMOUNT=0                    # Tax rate (0 = no tax)
FREE_DELIVERY_THRESHOLD=999     # Free delivery for orders above this amount
SHIPPING_FEE=50                 # Standard shipping fee

# Console Protection
# Set to true in production to disable console logs
SHOW_CONSOLE_WARNING=false

# Available Countries (JSON string)
AVAILABLE_COUNTRIES=["Bangladesh","United States","Canada","United Kingdom","Australia","Germany","France","India","Japan","China"]

# Environment
NODE_ENV=development
APP_ENV=development

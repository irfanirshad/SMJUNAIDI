# Server Configuration
PORT=8000
NODE_ENV=development
SERVER_URL=http://localhost:8000
PRODUCTION_SERVER_URL=https://api.yourdomain.com

# Client URLs (for CORS config)
ADMIN_URL=http://localhost:5173
CLIENT_URL=http://localhost:3000

# Database Connection
# MongoDB Connection String (Atlas or Local)
# Link: https://cloud.mongodb.com/
MONGO_URI="mongodb+srv://testingma23:testing324@cluster0.yqmepgw.mongodb.net/?appName=Cluster0"

# Security
# Secret key for signing JSON Web Tokens
JWT_SECRET="6cc2fb0638327e9e3c6e257f8a4c2129"

# Razorpay Payments
# Link: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=optional_webhook_secret

# Order Settings
TAX_RATE=0
FREE_DELIVERY_THRESHOLD=999

# Image Upload Provider (cloudinary or s3)
DEFAULT_UPLOAD_PROVIDER=cloudinary
MAX_PRODUCT_IMAGES=5
DEFAULT_USER_IMAGE=https://example.com/default-avatar.png

# Cloudinary Configuration (if provider is cloudinary)
# Link: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# AWS S3 Configuration (if provider is s3)
# Link: https://s3.console.aws.amazon.com/
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=...

# Email Service (Gmail OAuth2)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SENDER_EMAIL_ADDRESS=your-email@gmail.com

# Gmail API Credentials (Get these from Google Cloud Console)
# Link: https://console.cloud.google.com/apis/credentials
MAIL_CLIENT_ID=your_oauth_client_id
MAIL_CLIENT_SECRET=your_oauth_client_secret
MAIL_REFRESH_TOKEN=your_oauth_refresh_token

# Payment Defaults
# Currency used for Razorpay charges (typically INR)
PAYMENT_CURRENCY=INR
# Optional: multiply cart totals before sending to Razorpay (e.g., USD->INR ~83)
PAYMENT_CURRENCY_RATE=1
